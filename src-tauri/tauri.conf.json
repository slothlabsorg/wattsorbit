{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WattsOrbit",
  "version": "1.1.0",
  "identifier": "io.slothlabs.wattsorbit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1423",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WattsOrbit",
        "width": 380,
        "height": 460,
        "minWidth": 340,
        "minHeight": 300,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false
      },
      {
        "label": "dashboard",
        "title": "WattsOrbit \u2014 Dashboard",
        "width": 860,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxMzdBODAyMjdGQTVCNDYKUldSR1cvb25BcWczNGJESU9xTXRZZmRaTVdBa3dFN1NHeGdSUWlKcjhwOHZWa3RMMHl2SUsyRUkK",
      "endpoints": [
        "https://raw.githubusercontent.com/slothlabsorg/wattsorbit/main/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0 (>= 2.38)",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libnotify-bin"
        ]
      }
    }
  }
}
