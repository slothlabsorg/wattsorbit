# Copy this file to .env.production and fill in the values.
# .env.production is gitignored — never commit real keys.

# Sentry DSN for automatic crash reporting (optional).
# Get yours at https://sentry.io — free tier is enough for a small app.
# 1. Create a new project → select "React"
# 2. Copy the DSN from Project Settings > Client Keys
# 3. Paste it here
#
# If this is left empty, the app ships without Sentry (no crashes are reported
# automatically, but users can still use the "Report issue" button).
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id
